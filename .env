# KnowHealth Configuration

# App
APP_NAME=KnowHealth
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=postgresql://knowhealth:password@localhost:5432/knowhealth
REDIS_URL=redis://localhost:6379/0

# AI APIs
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Translation
DEEPL_API_KEY=your-deepl-key

# Storage (AWS S3 or Aliyun OSS)
STORAGE_PROVIDER=local
STORAGE_BUCKET=knowhealth-records
STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# Payment
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
ALIPAY_APP_ID=your-alipay-app-id
WECHAT_PAY_MCH_ID=your-wechat-mch-id

# Security
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=your-encryption-key

# Email/SMS
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-sms-key
SMS_SECRET=your-sms-secret

# HIPAA Compliance
ENABLE_AUDIT_LOG=true
DATA_RETENTION_DAYS=2555
ENCRYPT_AT_REST=true
